      "VFS Import SSH Key" : {
        "Type" : "Job:EmbeddedScript",
        "Script" : "#!/bin/bash\\nset +x\\n\\nVAR_SSH_NEW_KEY_PUB=$(env | grep \"^VAR_VFS_SSH_NEW_KEY_PUB=\" | cut -d= -f2-)\\n\\n# Compute the right authorized_keys file path\\nUSER_NAME=$(whoami)\\nUSER_HOME=$(getent passwd \"${USER_NAME}\" | cut -d: -f6)\\nUSER_AUTH_FILE=\"${USER_HOME}/.ssh/authorized_keys\"\\n\\n# Sanitize: remove backslashes and line breaks\\nVAR_SSH_NEW_KEY_PUB=\"$(\\n  printf '%s' \"$VAR_SSH_NEW_KEY_PUB\" \\\\n  | tr -d '\\\\\\n' \\\\n  | xargs\\n)\"\\n\\n# Append the new SSH key to authorized_keys\\necho \"${VAR_SSH_NEW_KEY_PUB}\" >> \"${USER_AUTH_FILE}\"",
        "SubApplication" : "%%VFS_SSH_HOST_NAME",
        "FileName" : "vfs.agentless.import.ssh.key.simple.sh",
        "Host" : "SSH_KEY_TARGET",
        "CreatedBy" : "orchestrator@bmc.com",
        "RunOnAllAgentsInGroup" : true,
        "RunAs" : "planets",
        "Application" : "SSH Key Orchestration",
        "Variables" : [ {
          "VAR_VFS_SSH_NEW_KEY_PUB" : "%%VFS_SSH_NEW_KEY_PUB"
        } ],
        "When" : {
