###############################################################################
# MFTE Operations Framework
###############################################################################

MFTE_VERSION=1.0
MFTE_ENVIRONMENT="LAB"

###############################################################################
# Product
###############################################################################

MFTE_HOME=/opt/werkstatt
MFTE_OPS_HOME=${MFTE_HOME}/ops

MFTE_FTS_HOME=/opt/controlm/ctm/cm/AFT/ftshome/
MFTE_B2B_HOME=${MFTE_FTS_HOME}/b2bhome

###############################################################################
# Directories
###############################################################################

MFTE_BIN_DIR=${MFTE_OPS_HOME}/bin
MFTE_CONFIG_DIR=${MFTE_OPS_HOME}/config
MFTE_CACHE_DIR=${MFTE_OPS_HOME}/cache
MFTE_COLLECTOR_DIR=${MFTE_OPS_HOME}/collectors
MFTE_DASHBOARD_DIR=${MFTE_OPS_HOME}/dashboards
MFTE_DOC_DIR=${MFTE_OPS_HOME}/docs
MFTE_EXPORTER_DIR=${MFTE_OPS_HOME}/exporters
MFTE_LIB_DIR=${MFTE_OPS_HOME}/lib
MFTE_LOG_DIR=${MFTE_OPS_HOME}/logs
MFTE_REPORT_DIR=${MFTE_OPS_HOME}/reports
MFTE_TMP_DIR=${MFTE_OPS_HOME}/tmp

###############################################################################
# Logging Targets 
###############################################################################

MFTE_JSONL_FILE=${MFTE_LOG_DIR}/processing/cluster.jsonl
MFTE_JSON_DIR=${MFTE_LOG_DIR}/processing/cluster.d
MFTE_SYSTEM_LOG_DIR=${MFTE_LOG_DIR}/system

###############################################################################
# Control-M
###############################################################################

MFTE_CONTROLM_HOME=/opt/controlm/ctm
MFTE_CONTROLM_PROCLOG=${MFTE_CONTROLM_HOME}/proclog

###############################################################################
# Apache Tika
###############################################################################

MFTE_TIKA_ENABLED=true
MFTE_TIKA_JAR=/opt/apache/tika

###############################################################################
# Logging Mode
###############################################################################

MFTE_LOG_LEVEL=INFO
MFTE_LOG_FORMAT=jsonl

###############################################################################
# Hashing
###############################################################################

MFTE_HASH_ALGORITHM=sha256

###############################################################################
# Cluster
###############################################################################

MFTE_CLUSTER=LAB
MFTE_ROLE=HUB
MFTE_SITE=LAB

###############################################################################
# Host
###############################################################################

MFTE_HOST_FQDN=$(hostname -f)
MFTE_HOST_NAME=$(hostname -s)


###############################################################################
# Privacy Guard - GPG
###############################################################################

# USER.name in data.mftgpg.json is the single source of truth for the
# service account name -- resolved here instead of hardcoded so a new
# environment only has to update data.mftgpg.json, not this file too.
MFTE_GPG_USER=$(jq -r '.USER.name' "${MFTE_CONFIG_DIR}/data.mftgpg.json")
MFTE_GPG_HOME=/home/${MFTE_GPG_USER}/.gnupg
MFTE_GPG_META_DIR=/home/${MFTE_GPG_USER}/mfte-gpg-meta
MFTE_GPG_PASSPHRASE_DIR=/home/${MFTE_GPG_USER}/mfte-gpg-passphrases
MFTE_GPG_OUTPUT_DIR=${MFTE_TMP_DIR}/mfte-gpg-out
MFTE_GPG_EXCHANGE_DIR=${MFTE_OPS_HOME}/privacy
MFTE_GPG_RETURN_DIR=${MFTE_B2B_HOME}/secureTransport
MFTE_GPG_RECEIVE_STAGING_DIR=${MFTE_TMP_DIR}/mfte-gpg-receive-staging

###############################################################################
# Privacy Guard - Onboarding
###############################################################################

MFTE_GPG_ONBOARDING_PRIVACY_DIR=${MFTE_GPG_EXCHANGE_DIR}/onboarding
MFTE_GPG_ONBOARDING_B2B_DIR=${MFTE_B2B_HOME}/secureTransport/onboarding

